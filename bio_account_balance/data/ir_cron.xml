<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Scheduled action to update balances every 15 minutes -->
    <!-- INACTIVE by default - activate manually if needed -->
    <record id="ir_cron_update_balances" model="ir.cron">
        <field name="name">Update Account Move Line Balances</field>
        <field name="model_id" ref="model_bio_account_move_line_balance"/>
        <field name="state">code</field>
        <field name="code">model.reset_and_update_balances()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="False"/>
        <field name="doall" eval="False"/>
        <field name="priority">10</field>
    </record>

</odoo>
