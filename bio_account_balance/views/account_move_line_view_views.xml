<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Journal Items with Balances - Fast View -->

    <!-- Tree View: Similar to account.move.line but with balance columns -->
    <record id="view_bio_account_move_line_view_tree" model="ir.ui.view">
        <field name="name">bio.account.move.line.view.tree</field>
        <field name="model">bio.account.move.line.view</field>
        <field name="arch" type="xml">
            <tree string="Journal Items" create="false" edit="false" expand="1" multi_edit="0" sample="1" default_order="sort_sequence">
                <field name="date" readonly="1"/>
                <field name="company_id" invisible="1"/>
                <field name="company_id" groups="base.group_multi_company" readonly="1" optional="hide"/>
                <field name="journal_id" readonly="1" options="{'no_open':True}" optional="hide"/>
                <field name="move_name" string="Journal Entry" widget="open_move_widget"/>
                <field name="account_id" options="{'no_open': True, 'no_create': True}" domain="[('company_id', '=', company_id)]" groups="account.group_account_readonly"/>
                <field name="partner_id" optional="show"/>
                <field name="ref" optional="hide" readonly="1"/>
                <field name="product_id" readonly="1" optional="hide"/>
                <field name="name" optional="show"/>
                <!-- Note: tax_ids and tax_tag_ids removed - many2many not supported in SQL VIEW -->
                <field name="amount_currency" groups="base.group_multi_currency" optional="show" readonly="1" attrs="{'invisible':[('is_same_currency', '=', True)]}"/>
                <field name="currency_id" readonly="1" groups="base.group_multi_currency" optional="hide" string="Currency" attrs="{'invisible':[('is_same_currency', '=', True)]}"/>

                <!-- Balance columns: ADDED -->
                <field name="bio_initial_balance" string="Initial Balance" optional="show"/>

                <field name="debit" sum="Total Debit" readonly="1"/>
                <field name="credit" sum="Total Credit" readonly="1"/>

                <!-- Balance columns: ADDED -->
                <field name="bio_end_balance" string="End Balance" optional="show"/>

                <field name="discount_date" string="Discount Date" optional="hide"/>
                <field name="discount_amount_currency" string="Discount Amount" optional="hide"/>
                <field name="tax_line_id" string="Originator Tax" optional="hide" readonly="1"/>
                <field name="date_maturity" readonly="1" optional="hide"/>
                <field name="balance" sum="Total Balance" optional="hide" readonly="1"/>
                <field name="matching_number" readonly="1" optional="show"/>
                <field name="amount_residual" sum="Total Residual" string="Residual" readonly="1" optional="hide" attrs="{'invisible':[('is_account_reconcile', '=', False)]}"/>
                <field name="amount_residual_currency" sum="Total Residual in Currency" string="Residual in Currency" readonly="1" optional="hide" attrs="{'invisible':['|', ('is_same_currency', '=', True), ('is_account_reconcile', '=', False)]}"/>
                <field name="analytic_distribution" widget="analytic_distribution" groups="analytic.group_analytic_accounting" optional="show" options="{'product_field': 'product_id', 'account_field': 'account_id', 'force_applicability': 'optional'}"/>
                <field name="analytic_precision" invisible="1"/>
                <field name="move_type" invisible="1"/>
                <field name="parent_state" invisible="1"/>
                <field name="account_type" invisible="1"/>
                <field name="statement_line_id" invisible="1"/>
                <field name="company_currency_id" invisible="1"/>
                <field name="is_same_currency" invisible="1"/>
                <field name="is_account_reconcile" invisible="1"/>
                <field name="sequence" invisible="1"/>
                <field name="sort_sequence" invisible="1"/>
                <groupby name="move_id">
                    <button string="View Entry" type="object" name="action_open_business_doc" icon="fa-external-link" context="{'create': False}"/>
                </groupby>
                <groupby name="partner_id">
                    <button name="edit" type="edit" icon="fa-edit" title="Edit"/>
                </groupby>
            </tree>
        </field>
    </record>

    <!-- Pivot View: Analytics with balance measures -->
    <record id="view_bio_account_move_line_view_pivot" model="ir.ui.view">
        <field name="name">bio.account.move.line.view.pivot</field>
        <field name="model">bio.account.move.line.view</field>
        <field name="arch" type="xml">
            <pivot string="Journal Items Analysis" sample="1" disable_linking="1">
                <!-- Default grouping: Account > Partner, Date by month in columns -->
                <field name="account_id" type="row"/>
                <field name="date" interval="month" type="col"/>

                <!-- Measures: amounts + balances (correctly calculated via override read_group) -->
                <field name="debit" type="measure"/>
                <field name="credit" type="measure"/>
                <field name="balance" type="measure"/>
                <field name="bio_initial_balance" type="measure" string="Initial Balance"/>
                <field name="bio_end_balance" type="measure" string="End Balance"/>
                <field name="amount_currency" type="measure" string="Amount in Currency"/>
                <field name="amount_residual" type="measure" string="Residual"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View: Visual analytics -->
    <record id="view_bio_account_move_line_view_graph" model="ir.ui.view">
        <field name="name">bio.account.move.line.view.graph</field>
        <field name="model">bio.account.move.line.view</field>
        <field name="arch" type="xml">
            <graph string="Balance Trends" type="line" sample="1">
                <field name="date" interval="month"/>
                <field name="bio_end_balance" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Search View: Filters similar to account.move.line -->
    <record id="view_bio_account_move_line_view_search" model="ir.ui.view">
        <field name="name">bio.account.move.line.view.search</field>
        <field name="model">bio.account.move.line.view</field>
        <field name="arch" type="xml">
            <search string="Search Journal Items">
                <!-- Quick filters -->
                <filter string="Posted" name="posted"
                        domain="[('parent_state', '=', 'posted')]"/>
                <separator/>
                <filter string="This Year" name="this_year"
                        domain="[('date', '&gt;=', context_today().strftime('%Y-01-01')),
                                 ('date', '&lt;=', context_today().strftime('%Y-12-31'))]"/>
                <filter string="This Month" name="this_month"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Positive Balance" name="positive_balance"
                        domain="[('bio_end_balance', '>', 0)]"/>
                <filter string="Negative Balance" name="negative_balance"
                        domain="[('bio_end_balance', '&lt;', 0)]"/>

                <!-- Search fields -->
                <field name="partner_id"/>
                <field name="account_id"/>
                <field name="journal_id"/>
                <field name="move_name"/>
                <field name="name"/>
                <field name="ref"/>
                <field name="product_id"/>

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter string="Partner" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Journal Entry" name="group_move" context="{'group_by': 'move_id'}"/>
                    <filter string="Account" name="group_account" context="{'group_by': 'account_id'}"/>
                    <filter string="Journal" name="group_journal" context="{'group_by': 'journal_id'}"/>
                    <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                    <separator/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                    <filter string="Due Date" name="group_date_maturity" context="{'group_by': 'date_maturity:month'}"/>
                    <separator/>
                    <filter string="Account Type" name="group_account_type" context="{'group_by': 'account_type'}"/>
                    <filter string="Move Type" name="group_move_type" context="{'group_by': 'move_type'}"/>
                    <separator/>
                    <filter string="Matching Number" name="group_matching" context="{'group_by': 'matching_number'}"/>
                    <separator/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: Journal Items with Balances -->
    <record id="action_bio_account_move_line_view" model="ir.actions.act_window">
        <field name="name">Journal Items (Balance)</field>
        <field name="res_model">bio.account.move.line.view</field>
        <field name="view_mode">pivot,tree,graph</field>
        <field name="search_view_id" ref="view_bio_account_move_line_view_search"/>
        <field name="context">{
            'search_default_posted': 1,
            'search_default_this_year': 1,
            'search_default_group_partner': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No journal items found
            </p>
            <p>
                This view shows journal items with real-time balance calculations.<br/>
                <b>⚡ Performance:</b> Fast SQL window functions for balance calculation<br/>
                <b>📋 Tree View:</b> Shows Initial Balance and End Balance per transaction (like Partner Ledger)<br/>
                <b>📊 Pivot View:</b> Analyze Debit/Credit/Balance aggregated by partner, account, period, etc.<br/>
                <b>✅ Advantage:</b> Real-time balances, no cron needed, always up-to-date
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <!-- Secondary menu: Under Accounting > Reporting -->
    <menuitem
        id="menu_bio_account_move_line_view_reports"
        name="Journal Items (Balance)"
        parent="account.menu_finance_entries_accounting_miscellaneous"
        action="action_bio_account_move_line_view"
        sequence="11"/>

</odoo>
