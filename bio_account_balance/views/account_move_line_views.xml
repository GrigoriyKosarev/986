<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Tree view: add balance fields to journal items list -->
    <record id="bio_view_move_line_tree" model="ir.ui.view">
        <field name="name">bio.account.balance.view.move.line.list</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <!--
                CRITICAL: Set default_order to match SQL window function ORDER BY (date, id)
                This ensures balances are displayed correctly in tree view.
                Without this, users could click columns to sort differently and balances would appear wrong
                (though they're calculated correctly, just displayed out of chronological order).
                ODOO-834
            -->
            <xpath expr="//tree" position="attributes">
                <attribute name="default_order">date,id</attribute>
            </xpath>
            <!-- Add "Refresh Balances" button in header -->
            <xpath expr="//tree" position="inside">
                <header>
                    <button name="%(bio_account_balance.bio_action_server_reset_balances)d"
                            type="action"
                            string="Refresh Balances"
                            class="btn-secondary"
                            help="Manually recalculate all balances (normally updated every 15 minutes by cron)"/>
                </header>
            </xpath>
            <xpath expr="//field[@name='debit']" position="before">
                <field name="bio_initial_balance"/>
            </xpath>
            <xpath expr="//field[@name='credit']" position="after">
                <field name="bio_end_balance"/>
            </xpath>
        </field>
    </record>

    <!-- Pivot view: add balance measures -->
    <record id="bio_view_move_line_pivot" model="ir.ui.view">
        <field name="name">bio.account.balance.view.move.line.pivot</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//pivot" position="inside">
                <!-- Hide these fields from Measures menu (they shouldn't be aggregated) -->
                <field name="bio_initial_balance" invisible="1"/>
                <field name="bio_end_balance" invisible="1"/>
                <!-- Show only dynamic balance fields in Measures menu -->
                <field name="bio_opening_by_partner" type="measure" string="Initial Balance"/>
                <field name="bio_closing_by_partner" type="measure" string="End Balance"/>
            </xpath>
        </field>
    </record>

</odoo>
