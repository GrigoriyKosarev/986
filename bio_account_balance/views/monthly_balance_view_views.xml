<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Monthly Balance View - Fast Pivot -->

    <!-- Pivot View: Main analytics view -->
    <record id="view_bio_monthly_balance_pivot" model="ir.ui.view">
        <field name="name">bio.monthly.balance.view.pivot</field>
        <field name="model">bio.monthly.balance.view</field>
        <field name="arch" type="xml">
            <pivot string="Monthly Balance Analysis" sample="1">
                <!-- Default grouping: Year > Month > Partner -->
                <field name="year" type="col"/>
                <field name="month" type="row"/>
                <field name="partner_id" type="row"/>

                <!-- Measures (default: opening + closing balance) -->
                <field name="opening_balance" type="measure"/>
                <field name="closing_balance" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View: Trends visualization -->
    <record id="view_bio_monthly_balance_graph" model="ir.ui.view">
        <field name="name">bio.monthly.balance.view.graph</field>
        <field name="model">bio.monthly.balance.view</field>
        <field name="arch" type="xml">
            <graph string="Balance Trends" type="line" sample="1">
                <field name="year"/>
                <field name="month"/>
                <field name="closing_balance" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Tree View: List for export/review -->
    <record id="view_bio_monthly_balance_tree" model="ir.ui.view">
        <field name="name">bio.monthly.balance.view.tree</field>
        <field name="model">bio.monthly.balance.view</field>
        <field name="arch" type="xml">
            <tree string="Monthly Balances" create="false" edit="false" delete="false">
                <field name="year"/>
                <field name="month"/>
                <field name="partner_id"/>
                <field name="account_id"/>
                <field name="opening_balance" sum="Total Opening"/>
                <field name="closing_balance" sum="Total Closing"/>
                <field name="balance_change" sum="Total Change"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- Search View: Filters and grouping -->
    <record id="view_bio_monthly_balance_search" model="ir.ui.view">
        <field name="name">bio.monthly.balance.view.search</field>
        <field name="model">bio.monthly.balance.view</field>
        <field name="arch" type="xml">
            <search string="Search Monthly Balances">
                <!-- Filters -->
                <filter string="Current Year" name="current_year"
                        domain="[('year', '=', context_today().year)]"/>
                <filter string="Last Year" name="last_year"
                        domain="[('year', '=', context_today().year - 1)]"/>
                <separator/>
                <filter string="Positive Balance" name="positive"
                        domain="[('closing_balance', '>', 0)]"/>
                <filter string="Negative Balance" name="negative"
                        domain="[('closing_balance', '&lt;', 0)]"/>

                <!-- Search fields -->
                <field name="partner_id"/>
                <field name="account_id"/>
                <field name="year"/>
                <field name="month"/>

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter string="Partner" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Account" name="group_account" context="{'group_by': 'account_id'}"/>
                    <separator/>
                    <filter string="Year" name="group_year" context="{'group_by': 'year'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'month'}"/>
                    <separator/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: Monthly Balance Pivot -->
    <record id="action_bio_monthly_balance_pivot" model="ir.actions.act_window">
        <field name="name">Monthly Balance Analysis (Fast)</field>
        <field name="res_model">bio.monthly.balance.view</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="search_view_id" ref="view_bio_monthly_balance_search"/>
        <field name="context">{
            'search_default_current_year': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No monthly balance data found
            </p>
            <p>
                This view shows pre-calculated monthly balances for fast analysis.<br/>
                <b>⚡ Performance:</b> ~100x faster than standard pivot!<br/>
                <b>📊 Use for:</b> Monthly/yearly trends, partner overview<br/>
                <b>⚠️ Limitation:</b> Monthly granularity only
            </p>
        </field>
    </record>

    <!-- Menu Items -->

    <!-- Main menu: Under Accounting > Accounting (next to Journal Items) -->
    <menuitem
        id="menu_bio_monthly_balance_pivot_main"
        name="Monthly Balance (Fast)"
        parent="account.menu_finance_entries"
        action="action_bio_monthly_balance_pivot"
        sequence="6"/>

    <!-- Secondary menu: Under Accounting > Reporting (for reports section) -->
    <menuitem
        id="menu_bio_monthly_balance_pivot"
        name="Monthly Balance (Fast)"
        parent="account.menu_finance_reports"
        action="action_bio_monthly_balance_pivot"
        sequence="99"/>

</odoo>
