<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard Form View -->
    <record id="view_period_filter_wizard_form" model="ir.ui.view">
        <field name="name">bio.period.filter.wizard.form</field>
        <field name="model">bio.period.filter.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Custom Period">
                <group>
                    <group>
                        <field name="period_start" required="1"/>
                    </group>
                    <group>
                        <field name="period_end" required="1"/>
                    </group>
                </group>
                <footer>
                    <button string="Apply" type="object" name="action_apply_filter" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_period_filter_wizard" model="ir.actions.act_window">
        <field name="name">Custom Period</field>
        <field name="res_model">bio.period.filter.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
